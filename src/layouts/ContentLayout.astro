---
import BaseLayout from './BaseLayout.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  noindex?: boolean;
}

const { eyebrow, title, description, seoTitle, seoDescription, noindex } = Astro.props;
---

<BaseLayout title={seoTitle ?? `${title} | Tedd Schreiner`} description={seoDescription ?? description} noindex={noindex}>
  <section class="section">
    <div class="container-page">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="mt-3 max-w-4xl text-4xl font-semibold text-zinc-950 sm:text-5xl">{title}</h1>
      <p class="section-copy">{description}</p>
    </div>
  </section>
  <slot />
</BaseLayout>
