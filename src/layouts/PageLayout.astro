---
import Container from '@components/Container.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  publishedTime?: string;
  modifiedTime?: string;
}

const props = Astro.props as Props;
---

<BaseLayout
  title={props.seoTitle ?? `${props.title} | Tedd Schreiner`}
  description={props.seoDescription ?? props.description}
  canonical={props.canonical}
  image={props.image}
  imageAlt={props.imageAlt}
  noindex={props.noindex}
  type={props.type}
  jsonLd={props.jsonLd}
  publishedTime={props.publishedTime}
  modifiedTime={props.modifiedTime}
>
  <section class="section">
    <Container>
      {props.eyebrow && <p class="eyebrow">{props.eyebrow}</p>}
      <h1 class="mt-3 max-w-4xl text-4xl font-semibold leading-tight text-[color:var(--ink)] sm:text-5xl">
        {props.title}
      </h1>
      <p class="section-copy">{props.description}</p>
    </Container>
  </section>
  <slot />
</BaseLayout>
