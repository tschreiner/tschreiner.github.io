---
import Container from '@components/Container.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}
---

<BaseLayout
  title={Astro.props.seoTitle ?? `${Astro.props.title} | Tedd Schreiner`}
  description={Astro.props.seoDescription ?? Astro.props.description}
  noindex={Astro.props.noindex}
  type={Astro.props.type}
  jsonLd={Astro.props.jsonLd}
>
  <section class="section">
    <Container>
      {Astro.props.eyebrow && <p class="eyebrow">{Astro.props.eyebrow}</p>}
      <h1 class="mt-3 max-w-4xl text-4xl font-semibold leading-tight text-[color:var(--ink)] sm:text-5xl">
        {Astro.props.title}
      </h1>
      <p class="section-copy">{Astro.props.description}</p>
    </Container>
  </section>
  <slot />
</BaseLayout>
