---
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import SEOHead from '@components/SEOHead.astro';
import { site } from '@lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  publishedTime?: string;
  modifiedTime?: string;
}

const props = Astro.props as Props;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: 'DevOps Engineer für Cloud Automation und AI Software Engineering',
  sameAs: [site.social.github, site.social.linkedin, site.social.xing].filter(Boolean),
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
};

const propsJsonLd = props.jsonLd
  ? Array.isArray(props.jsonLd)
    ? props.jsonLd
    : [props.jsonLd]
  : [];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#edf3f5" />
    <SEOHead
      title={props.title}
      description={props.description}
      canonical={props.canonical}
      image={props.image}
      imageAlt={props.imageAlt}
      noindex={props.noindex}
      type={props.type}
      jsonLd={[personJsonLd, websiteJsonLd, ...propsJsonLd]}
      publishedTime={props.publishedTime}
      modifiedTime={props.modifiedTime}
    />
  </head>
  <body>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
