---
import AnalyticsConsent from '@components/AnalyticsConsent.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import SEOHead from '@components/SEOHead.astro';
import { googleAnalyticsId } from '@lib/analytics';
import { defaultSeoImage, imageUrl } from '@lib/seo';
import { site } from '@lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  publishedTime?: string;
  modifiedTime?: string;
}

const props = Astro.props as Props;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: 'DevOps Engineer für Cloud Automation und AI Software Engineering',
  image: imageUrl(defaultSeoImage),
  sameAs: [site.social.github, site.social.linkedin, site.social.xing].filter(Boolean),
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
};

const propsJsonLd = props.jsonLd
  ? Array.isArray(props.jsonLd)
    ? props.jsonLd
    : [props.jsonLd]
  : [];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline define:vars={{ googleAnalyticsId }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() {
        window.dataLayer.push(arguments);
      };
      window.gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
      });
      window.googleAnalyticsId = googleAnalyticsId;
    </script>
    <SEOHead
      title={props.title}
      description={props.description}
      canonical={props.canonical}
      image={props.image}
      imageAlt={props.imageAlt}
      noindex={props.noindex}
      type={props.type}
      jsonLd={[personJsonLd, websiteJsonLd, ...propsJsonLd]}
      publishedTime={props.publishedTime}
      modifiedTime={props.modifiedTime}
    />
  </head>
  <body>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
    <AnalyticsConsent />
    <script>
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (!motionQuery.matches && 'IntersectionObserver' in window) {
        const revealItems = document.querySelectorAll<HTMLElement>(
          '.section .surface-card, .section .project-card, .section .blog-card, .section .feature-card, .section .timeline-list > li',
        );

        revealItems.forEach((item) => {
          item.dataset.reveal = '';
        });

        document.documentElement.classList.add('reveal-ready');

        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: '0px 0px -12% 0px', threshold: 0.12 },
        );

        revealItems.forEach((item) => revealObserver.observe(item));
      }

      const sectionLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-section-link]'));
      const projectSections = Array.from(document.querySelectorAll<HTMLElement>('[data-project-section]'));

      if (sectionLinks.length > 0 && projectSections.length > 0 && 'IntersectionObserver' in window) {
        const setActiveSection = (id: string) => {
          sectionLinks.forEach((link) => {
            link.dataset.active = link.dataset.sectionLink === id ? 'true' : 'false';
          });
        };

        const sectionObserver = new IntersectionObserver(
          (entries) => {
            const visibleEntry = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

            if (visibleEntry?.target.id) {
              setActiveSection(visibleEntry.target.id);
            }
          },
          { rootMargin: '-22% 0px -58% 0px', threshold: [0.1, 0.35, 0.6] },
        );

        projectSections.forEach((section) => sectionObserver.observe(section));
        setActiveSection(projectSections[0]?.id ?? '');
      }
    </script>
  </body>
</html>
