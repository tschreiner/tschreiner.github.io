---
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TechTag from '@components/TechTag.astro';
import TimelineItem from '@components/TimelineItem.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byExperienceDateDesc } from '@lib/content';
import { education, languages, skillClusters } from '@lib/site';
import { getCollection } from 'astro:content';

const experience = (await getCollection('experience')).sort(byExperienceDateDesc);
const suitableRoles = [
  'DevOps Engineer',
  'AWS Cloud Engineer',
  'Platform Engineer',
  'Infrastructure Automation Engineer',
  'CI/CD Engineer',
  'Network Automation Engineer',
  'AI Software Engineer mit Automatisierungsfokus',
];
---

<PageLayout
  eyebrow="CV / Lebenslauf"
  title="Lebenslauf"
  description="Aktuelle Rolle, technische Schwerpunkte und relevante Erfahrung für DevOps-, AWS-Cloud-, Platform-, Automation- und AI-Software-Engineering-Rollen."
  tags={['DevOps', 'AWS Cloud', 'CI/CD', 'Network Automation']}
>
  <section class="section section-after-header">
    <Container class="grid gap-8 lg:grid-cols-[0.68fr_1.32fr]">
      <div class="lg:col-start-2 lg:row-start-1">
        <ol class="timeline-list" aria-label="Berufserfahrung">
          {experience.map((item) => <li><TimelineItem item={item} /></li>)}
        </ol>
      </div>

      <aside class="grid content-start gap-5 lg:sticky lg:top-24 lg:col-start-1 lg:row-start-1">
        <div class="surface-card overflow-hidden p-0">
          <img
            src="/images/profile.jpg"
            alt="Portrait von Tedd Schreiner"
            width="1200"
            height="1223"
            loading="lazy"
            decoding="async"
            class="aspect-[5/4] w-full object-cover object-[50%_58%]"
          />
          <div class="p-6">
            <p class="eyebrow">Kurzprofil</p>
            <h2 class="mt-3 text-xl font-semibold text-[color:var(--ink)]">Tedd Schreiner</h2>
            <p class="mt-1 text-sm font-medium text-[color:var(--accent-dark)]">DevOps Engineer · Cloud · Automation</p>
            <p class="mt-4 text-sm leading-7 text-[color:var(--muted-strong)]">
              DevOps Engineer mit Fokus auf AWS Cloud, CI/CD, Kubernetes, Infrastrukturautomatisierung, Netzwerkautomatisierung, ITSM-Prozesse und AI Software Engineering.
            </p>
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Technisches Profil</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">
            Infrastruktur, Automatisierung und Betrieb mit Blick auf nachvollziehbare Daten, stabile Workflows und wartbare technische Systeme.
          </p>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Passende Rollen</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {suitableRoles.map((role) => <TechTag label={role} />)}
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Für Recruiter</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">
            Für eine schnelle Einschätzung helfen Rollenprofil, Tech Stack, Remote-/Hybrid-Regelung, Standort, Startzeitpunkt und Gehalts- oder Budgetrahmen.
          </p>
        </div>
        <div class="grid gap-4">
          {skillClusters.map((cluster) => <SkillCluster {...cluster} />)}
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Ausbildung</h2>
          <div class="mt-4 grid gap-4">
            {education.map((item) => (
              <div>
                <p class="font-medium text-[color:var(--ink)]">{item.title}</p>
                <p class="mt-1 text-sm text-[color:var(--muted-strong)]">{item.institution} · {item.date}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Sprachen</h2>
          <div class="mt-4 grid gap-2">
            {languages.map((language) => (
              <p class="text-sm text-[color:var(--muted-strong)]"><strong>{language.name}:</strong> {language.level}</p>
            ))}
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section section-tight-top">
    <Container>
      <ContactPanel />
    </Container>
  </section>
</PageLayout>
