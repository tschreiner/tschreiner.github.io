---
import ContentLayout from '@layouts/ContentLayout.astro';
import { education, experience, languages, skills } from '@lib/site';
---

<ContentLayout
  eyebrow="CV / Lebenslauf"
  title="Lebenslauf"
  description="Aktuelle Rollen, relevante Erfahrung, Skills, Ausbildung und Sprachen in kompakter Form."
>
  <section class="section pt-0">
    <div class="container-page grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
      <aside class="grid content-start gap-5">
        <div class="card">
          <h2 class="text-lg font-semibold text-zinc-950">Skills</h2>
          <div class="mt-4 grid gap-4">
            {skills.map((skill) => (
              <div>
                <h3 class="text-sm font-semibold text-teal-800">{skill.group}</h3>
                <div class="mt-2 flex flex-wrap gap-2">
                  {skill.items.map((item) => <span class="tag">{item}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="card">
          <h2 class="text-lg font-semibold text-zinc-950">Ausbildung</h2>
          <div class="mt-4 grid gap-4">
            {education.map((item) => (
              <div>
                <p class="font-medium text-zinc-950">{item.title}</p>
                <p class="mt-1 text-sm text-zinc-600">{item.institution} · {item.date}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="card">
          <h2 class="text-lg font-semibold text-zinc-950">Sprachen</h2>
          <div class="mt-4 grid gap-2">
            {languages.map((language) => (
              <p class="text-sm text-zinc-700"><strong>{language.name}:</strong> {language.level}</p>
            ))}
          </div>
        </div>
      </aside>

      <div class="grid gap-5">
        {experience.map((job) => (
          <article class="card">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold text-zinc-950">{job.role}</h2>
                <p class="mt-1 text-sm font-medium text-teal-800">{job.company} · {job.location}</p>
              </div>
              <p class="text-sm text-zinc-500">{job.duration}</p>
            </div>
            <ul class="mt-5 grid gap-2 leading-7 text-zinc-700">
              {job.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</ContentLayout>
