---
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@lib/site';
---

<PageLayout
  eyebrow="Kontakt"
  title="Kontakt aufnehmen"
  description="Kontakt für passende DevOps-, AWS-Cloud-, Automation- und AI-Software-Engineering-Anfragen."
>
  <section class="section section-after-header">
    <Container class="grid gap-6 md:grid-cols-[1.12fr_0.88fr]">
      <ContactPanel />
      <div class="surface-card">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Profile</h2>
        <div class="mt-5 grid gap-3">
          <a class="button-secondary justify-start" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="button-secondary justify-start" href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a class="button-secondary justify-start" href={site.social.xing} target="_blank" rel="noopener noreferrer">Xing</a>
        </div>
      </div>
      <div class="surface-card md:col-span-2 sm:p-8">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Passende Anfragen</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          Passend sind Rollen und Projekte, in denen technische Abläufe zuverlässiger, nachvollziehbarer und stärker
          automatisiert werden sollen — von Cloud-Infrastruktur über Deployment-Workflows bis zu ITSM- und
          Netzwerkprozessen.
        </p>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          <li class="meta-chip justify-start">DevOps- und AWS-Cloud-Rollen</li>
          <li class="meta-chip justify-start">Platform Engineering und Kubernetes-nahe Themen</li>
          <li class="meta-chip justify-start">CI/CD, GitHub/GitLab Workflows und Software Deployment</li>
          <li class="meta-chip justify-start">Infrastruktur-, Netzwerk- und ITSM-Automatisierung</li>
          <li class="meta-chip justify-start sm:col-span-2">
            AI Software Engineering und AI-gestützte Engineering-Workflows
          </li>
        </ul>
      </div>
      <div class="surface-card md:col-span-2 sm:p-8">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Bitte mitsenden</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          Für eine schnelle Einschätzung sind Rollenbeschreibung, Tech Stack, Vertragsart, Remote-/Hybrid-Regelung,
          Standort, Startzeitpunkt und Gehalts- oder Budgetrahmen hilfreich.
        </p>
      </div>
    </Container>
  </section>
</PageLayout>
