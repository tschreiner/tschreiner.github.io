---
import Container from '@components/Container.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { getSite } from '@lib/site';

const locale = 'en' as const;
const site = getSite(locale);
---

<PageLayout
  eyebrow="Separate Project"
  title="Dating profile mentoring as a separate side project"
  description="A factual bridge page to a small side project around dating profiles, deliberately separated from the technical focus of this website."
  tags={['Mentoring', 'Profile Clarity', 'Separate Offer']}
  locale={locale}
>
  <section class="section section-after-header">
    <Container class="grid gap-8 lg:grid-cols-[1.12fr_0.88fr]">
      <div class="surface-card prose-site sm:p-8">
        <p>
          Many dating profiles do not fail because someone is uninteresting. They fail because strong qualities do not
          become visible: humor, reliability, curiosity, calmness, character.
        </p>
        <p>
          That is exactly where this separate project begins: respectful, honest and without forcing an artificial role.
          It is aimed at analytically minded men who want to communicate more clearly on dating apps while still being
          themselves.
        </p>
        <p>
          This page intentionally stays separate. The topic sits next to the technical positioning of the main website;
          professional contact paths and the main navigation remain focused on DevOps, projects and technical work.
        </p>
      </div>
      <aside class="surface-card h-fit sm:p-8">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Interested?</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          For an initial conversation or a quick question, a short message is enough.
        </p>
        <div class="mt-6 grid gap-3">
          <a class="button-primary" href={`mailto:${site.email}?subject=Interested%20in%20dating%20profile%20mentoring`}>
            Show interest
          </a>
          <a class="button-secondary" href={`mailto:${site.email}?subject=Request%20a%20free%20introductory%20call`}>
            Request a free intro call
          </a>
          <a class="button-secondary" href={`mailto:${site.email}`}>Send a message</a>
        </div>
      </aside>
    </Container>
  </section>
</PageLayout>
