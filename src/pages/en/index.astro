---
import BlogCard from '@components/BlogCard.astro';
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import FitCardGrid from '@components/FitCardGrid.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TimelineItem from '@components/TimelineItem.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { byExperienceDateDesc, byProjectTitleForLocale, byPubDateDesc } from '@lib/content';
import { getSite, getSkillClusters, getSuitableInquiryAreas } from '@lib/site';
import { getCollection } from 'astro:content';

const locale = 'en' as const;
const site = getSite(locale);
const skillClusters = getSkillClusters(locale);
const suitableInquiryAreas = getSuitableInquiryAreas(locale);
const projects = (await getCollection('projectsEn'))
  .filter((project) => project.data.locale === locale && project.data.featured)
  .sort(byProjectTitleForLocale(locale));
const posts = (await getCollection('blog'))
  .filter((post) => post.data.locale === locale && !post.data.draft)
  .sort(byPubDateDesc)
  .slice(0, 3);
const experience = (await getCollection('experience'))
  .filter((item) => item.data.locale === locale)
  .sort(byExperienceDateDesc)
  .slice(0, 2);
---

<BaseLayout title={site.title} description={site.description} locale={locale}>
  <Hero />

  <section class="section section-soft">
    <Container>
      <div class="max-w-3xl">
        <p class="eyebrow">Role Profile</p>
        <h2 class="section-title">Relevant for roles at the intersection of cloud, automation and operations.</h2>
        <p class="section-copy">
          I am especially well suited for roles where infrastructure, deployments and technical workflows should become
          more reliable, more traceable and more automated.
        </p>
      </div>

      <FitCardGrid items={suitableInquiryAreas} class="mt-10" />
    </Container>
  </section>

  <section class="section section-dark">
    <Container class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div>
        <p class="eyebrow text-[color:var(--gold)]">Technical Focus</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">
          Cloud infrastructure, deployment automation and operations considered as one system.
        </h2>
        <p class="mt-5 max-w-xl leading-8 text-[color:var(--warm-muted)]">
          My work connects AWS-focused infrastructure, CI/CD, Kubernetes, ITSM workflows, network automation and
          AI-assisted engineering workflows. The common thread: systems should become easier to understand, more
          reliable and easier to automate.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {skillClusters.map((cluster) => <SkillCluster {...cluster} dark />)}
      </div>
    </Container>
  </section>

  <section class="section section-tight-bottom">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Case Studies</p>
          <h2 class="section-title">Selected project examples from infrastructure, automation and network operations.</h2>
          <p class="section-copy">
            These project pages are intentionally anonymized. They show the problem, solution, technologies, outcome and
            lessons learned without exposing confidential operational details.
          </p>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/en/projects/">All projects</a>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>

  <section class="section section-tight-y">
    <Container>
      <p class="eyebrow">Career Snapshot</p>
      <h2 class="section-title">The through line: understand systems, structure them and automate them.</h2>
      <p class="section-copy">
        The full CV remains available, but on the homepage the most important part is the connection: development,
        infrastructure, automation and operations come together into one clear technical profile.
      </p>

      <ol class="timeline-list mt-10 max-w-4xl" aria-label="Career experience overview">
        {experience.map((item) => <li><TimelineItem item={item} /></li>)}
      </ol>

      <div class="mt-5 pl-8 sm:pl-10">
        <a class="button-secondary" href="/en/cv/">Open full CV</a>
      </div>
    </Container>
  </section>

  <section class="section section-tight-top">
    <Container>
      <ContactPanel />
    </Container>
  </section>

  {posts.length > 0 && (
    <section class="section section-soft">
      <Container>
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div>
            <p class="eyebrow">Blog</p>
            <h2 class="section-title">Notes on DevOps, network data and technical projects.</h2>
            <p class="section-copy">
              The blog is meant for practical notes: decisions, learnings, small experiments and technical connections
              that do not fit neatly into a classic project page.
            </p>
          </div>
          <a class="button-secondary self-start md:self-auto" href="/en/blog/">Go to blog</a>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
