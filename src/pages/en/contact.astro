---
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import FitCardGrid from '@components/FitCardGrid.astro';
import SocialIcon from '@components/SocialIcon.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { getSite, getSuitableInquiryAreas } from '@lib/site';

const locale = 'en' as const;
const site = getSite(locale);
const suitableInquiryAreas = getSuitableInquiryAreas(locale);
---

<PageLayout
  eyebrow="Contact"
  title="Get in touch"
  description="Contact for relevant DevOps, AWS Cloud, automation and AI-assisted software engineering opportunities."
  tags={['Roles', 'Projects', 'Cloud', 'Automation']}
  locale={locale}
>
  <section class="section section-after-header">
    <Container class="grid gap-6 md:grid-cols-[1.12fr_0.88fr]">
      <ContactPanel />
      <div class="surface-card">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Profiles</h2>
        <div class="mt-5 grid gap-3">
          <a class="button-secondary justify-start gap-2" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="linkedin" />
            LinkedIn
          </a>
          <a class="button-secondary justify-start gap-2" href={site.social.xing} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="xing" />
            Xing
          </a>
          <a class="button-secondary justify-start gap-2" href={site.social.github} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="github" />
            GitHub
          </a>
        </div>
      </div>
      <div class="surface-card md:col-span-2 sm:p-8">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Relevant inquiries</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          Good fits are roles and projects where technical workflows should become more reliable, more traceable and
          more automated, from cloud infrastructure and deployment workflows to ITSM and network processes.
        </p>
        <FitCardGrid items={suitableInquiryAreas} class="mt-6" />
      </div>
      <div class="surface-card md:col-span-2 sm:p-8">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Helpful context to include</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          For a quick assessment it helps to include the role description, tech stack, contract type, remote or hybrid
          setup, location, start date and salary or budget range.
        </p>
      </div>
    </Container>
  </section>
</PageLayout>
