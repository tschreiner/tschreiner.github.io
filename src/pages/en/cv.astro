---
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TechTag from '@components/TechTag.astro';
import TimelineItem from '@components/TimelineItem.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byExperienceDateDesc } from '@lib/content';
import { getEducation, getLanguages, getSkillClusters } from '@lib/site';
import { getCollection } from 'astro:content';

const locale = 'en' as const;
const experience = (await getCollection('experience'))
  .filter((item) => item.data.locale === locale)
  .sort(byExperienceDateDesc);
const suitableRoles = [
  'DevOps Engineer',
  'AWS Cloud Engineer',
  'Platform Engineer',
  'Infrastructure Automation Engineer',
  'CI/CD Engineer',
  'Network Automation Engineer',
  'AI Software Engineer with an automation focus',
];
const profileFocus = ['DevOps Engineer', 'Cloud', 'Automation', 'AI-assisted Engineering'];
const skillClusters = getSkillClusters(locale);
const education = getEducation(locale);
const languages = getLanguages(locale);
---

<PageLayout
  eyebrow="CV"
  title="Curriculum Vitae"
  description="Current role, technical focus and relevant experience for DevOps, AWS Cloud, platform, automation and AI-assisted software engineering roles."
  tags={['DevOps', 'AWS Cloud', 'CI/CD', 'Network Automation', 'Software Engineering', 'Artificial Intelligence']}
  locale={locale}
>
  <section class="section section-after-header">
    <Container class="grid gap-8 lg:grid-cols-[0.68fr_1.32fr]">
      <div class="min-w-0 lg:col-start-2 lg:row-start-1">
        <ol class="timeline-list" aria-label="Professional experience">
          {experience.map((item) => <li><TimelineItem item={item} /></li>)}
        </ol>
      </div>

      <aside class="grid min-w-0 content-start gap-5 lg:sticky lg:top-24 lg:col-start-1 lg:row-start-1">
        <div class="surface-card overflow-hidden p-0">
          <img
            src="/images/profile.jpg"
            alt="Portrait of Tedd Schreiner"
            width="1200"
            height="1223"
            loading="lazy"
            decoding="async"
            class="aspect-[5/4] w-full object-cover object-[50%_58%]"
          />
          <div class="p-6">
            <p class="eyebrow">Short profile</p>
            <h2 class="mt-3 text-xl font-semibold text-[color:var(--ink)]">Tedd Schreiner</h2>
            <p class="mt-1 flex min-w-0 flex-wrap items-baseline text-sm font-medium leading-6 text-[color:var(--accent-dark)]">
              {
                profileFocus.map((item, index) => (
                  <span class="inline-flex items-baseline whitespace-nowrap">
                    <span>{item}</span>
                    {index < profileFocus.length - 1 && (
                      <span aria-hidden="true" class="mx-1 text-[color:var(--accent-soft)]">·</span>
                    )}
                  </span>
                ))
              }
            </p>
            <p class="mt-4 text-sm leading-7 text-[color:var(--muted-strong)]">
              DevOps Engineer focused on AWS Cloud, CI/CD, Kubernetes, infrastructure automation, network automation,
              ITSM workflows and AI-assisted software engineering.
            </p>
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Technical profile</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">
            Infrastructure, automation and operations with a focus on traceable data, stable workflows and maintainable
            technical systems.
          </p>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Relevant roles</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {suitableRoles.map((role) => <TechTag label={role} />)}
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Role context</h2>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">
            For a quick assessment, it helps to know the role profile, tech stack, remote or hybrid setup, location,
            start date and salary or budget range.
          </p>
        </div>
        <div class="grid gap-4">
          {skillClusters.map((cluster) => <SkillCluster {...cluster} />)}
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Education</h2>
          <div class="mt-4 grid gap-4">
            {education.map((item) => (
              <div>
                <p class="font-medium text-[color:var(--ink)]">{item.title}</p>
                <p class="mt-1 text-sm text-[color:var(--muted-strong)]">{item.institution} · {item.date}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="surface-card">
          <h2 class="text-lg font-semibold text-[color:var(--ink)]">Languages</h2>
          <div class="mt-4 grid gap-2">
            {languages.map((language) => (
              <p class="text-sm text-[color:var(--muted-strong)]"><strong>{language.name}:</strong> {language.level}</p>
            ))}
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section section-tight-top">
    <Container>
      <ContactPanel />
    </Container>
  </section>
</PageLayout>
