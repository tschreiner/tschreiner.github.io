---
import Callout from '@components/Callout.astro';
import Container from '@components/Container.astro';
import TechTag from '@components/TechTag.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { canonicalUrl as toCanonicalUrl, defaultSeoImage, defaultSeoImageAlt, imageUrl } from '@lib/seo';
import { site } from '@lib/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const hasConstraints = project.data.constraints.length > 0;
const hasApproach = project.data.approach.length > 0;
const hasLessons = project.data.lessons.length > 0;
const canonical = `/projects/${project.data.slug}/`;
const projectUrl = toCanonicalUrl(canonical);
const projectImage = project.data.cover ?? defaultSeoImage;
const projectImageAlt = project.data.cover
  ? `Open-Graph-Bild zur Case Study ${project.data.title}`
  : defaultSeoImageAlt;
const projectDescription = project.data.seo?.description ?? project.data.description;
const projectKeywords = Array.from(new Set([project.data.category, ...project.data.technologies].filter(Boolean)));
const projectImageUrl = imageUrl(projectImage);
const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: projectDescription,
  url: projectUrl,
  author: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  ...(projectKeywords.length > 0 ? { keywords: projectKeywords } : {}),
  ...(projectImageUrl ? { image: projectImageUrl } : {}),
};
---

<PageLayout
  eyebrow="Projekt"
  title={project.data.title}
  description={project.data.description}
  seoTitle={project.data.seo?.title}
  seoDescription={project.data.seo?.description}
  canonical={canonical}
  image={projectImage}
  imageAlt={projectImageAlt}
  jsonLd={projectJsonLd}
>
  <section class="section pt-0">
    <Container class="grid gap-8 lg:grid-cols-[0.66fr_1.34fr]">
      <aside class="surface-card h-fit sm:p-7 lg:sticky lg:top-24">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--accent-dark)]">Case Study</p>

        <div class="mt-5 space-y-5">
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-[color:var(--muted-strong)]">Status</h2>
            <p class="mt-2 font-medium text-[color:var(--ink)]">{project.data.status}</p>
          </div>

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-[color:var(--muted-strong)]">Kategorie</h2>
            <p class="mt-2 font-medium text-[color:var(--ink)]">{project.data.category}</p>
          </div>

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-[color:var(--muted-strong)]">Technologien</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.data.technologies.map((tech) => <TechTag label={tech} />)}
            </div>
          </div>
        </div>

        {project.data.confidentialNote && (
          <Callout title="Vertraulichkeit" tone="warning">
            <p>{project.data.confidentialNote}</p>
          </Callout>
        )}

        <a class="button-primary mt-6 w-full" href="/contact/">Über ähnliche Projekte sprechen</a>
      </aside>

      <article class="surface-card prose-site sm:p-8">
        <h2>Problem</h2>
        <p>{project.data.problem}</p>
        {project.data.context && (
          <>
            <h2>Kontext</h2>
            <p>{project.data.context}</p>
          </>
        )}
        {project.data.role && (
          <>
            <h2>Rolle / Beitrag</h2>
            <p>{project.data.role}</p>
          </>
        )}
        {hasConstraints && (
          <>
            <h2>Rahmenbedingungen</h2>
            <ul>
              {project.data.constraints.map((constraint) => <li>{constraint}</li>)}
            </ul>
          </>
        )}
        {hasApproach && (
          <>
            <h2>Vorgehen</h2>
            <ul>
              {project.data.approach.map((step) => <li>{step}</li>)}
            </ul>
          </>
        )}
        <h2>Lösung</h2>
        <p>{project.data.solution}</p>
        <h2>Ergebnis</h2>
        <p>{project.data.result}</p>
        {hasLessons && (
          <>
            <h2>Lessons Learned</h2>
            <ul>
              {project.data.lessons.map((lesson) => <li>{lesson}</li>)}
            </ul>
          </>
        )}
        <Content />
      </article>
    </Container>
  </section>
</PageLayout>
