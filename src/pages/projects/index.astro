---
import Container from '@components/Container.astro';
import ProjectCard from '@components/ProjectCard.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byProjectTitle } from '@lib/content';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(byProjectTitle);
---

<PageLayout
  eyebrow="Projekte"
  title="Case Studies zu Netzwerkautomatisierung, Source of Truth und technischen Labs."
  description="Anonymisierte Projektbeispiele aus DevOps, Infrastruktur, Netzwerkdaten und Automatisierung. Fokus: Problemraum, Rolle, Vorgehen, Ergebnis und Lernpunkte, ohne vertrauliche Details offenzulegen."
>
  <section class="section pt-0">
    <Container class="grid gap-5 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </Container>
  </section>
</PageLayout>
