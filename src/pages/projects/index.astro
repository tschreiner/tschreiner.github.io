---
import Container from '@components/Container.astro';
import ProjectCard from '@components/ProjectCard.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byProjectTitleForLocale } from '@lib/content';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.locale === 'de')
  .sort(byProjectTitleForLocale('de'));
---

<PageLayout
  eyebrow="Projekte"
  title="Case Studies zu Infrastruktur, Automatisierung, Netzwerkdaten und technischen Labs"
  description="Ausgewählte Projektbeispiele aus Infrastruktur, Automatisierung und Netzwerkbetrieb — mit Fokus auf Ausgangslage, Beitrag, Vorgehen und nachvollziehbare Ergebnisse"
  tags={['Case Studies', 'Infrastruktur', 'Automatisierung', 'Labs']}
>
  <section class="section section-after-header">
    <Container class="grid gap-5 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </Container>
  </section>
</PageLayout>
