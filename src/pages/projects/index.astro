---
import Container from '@components/Container.astro';
import ProjectCard from '@components/ProjectCard.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byProjectTitle } from '@lib/content';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(byProjectTitle);
---

<PageLayout
  eyebrow="Projekte"
  title="Projekte aus DevOps, Netzwerkautomatisierung und Lab-Aufbau."
  description="Ausgewählte Arbeiten, anonymisiert und auf Problem, Lösung, Technologien und Lernpunkte reduziert."
>
  <section class="section pt-0">
    <Container class="grid gap-5 md:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </Container>
  </section>
</PageLayout>
