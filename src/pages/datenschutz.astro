---
import Container from '@components/Container.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@lib/site';
---

<PageLayout
  eyebrow="Legal"
  title="Datenschutz"
  description="Vorläufige Datenschutzhinweise. Inhalte müssen vor Veröffentlichung final rechtlich geprüft werden."
  noindex={true}
>
  <section class="section pt-0">
    <Container>
      <div class="surface-card prose-site">
        <p><strong>TODO:</strong> Datenschutzerklärung final rechtlich prüfen und ergänzen. Dies ist keine Rechtsberatung.</p>
        <h2>Grundsatz</h2>
        <p>
          Diese Website ist als statische Astro-Seite geplant. Es werden keine Tracking-Skripte, keine externen Webfonts und
          keine externen Analyse- oder Tag-Management-Dienste eingebunden.
        </p>
        <h2>Hosting und Serverlogs</h2>
        <p>
          TODO: Cloudflare Pages als Hosting-Ziel mit passenden Hinweisen zu Serverlogs, CDN und Auftragsverarbeitung beschreiben.
        </p>
        <h2>Kontaktaufnahme</h2>
        <p>
          Bei Kontaktaufnahme per E-Mail werden die übermittelten Daten zur Bearbeitung der Anfrage verarbeitet.
          Kontakt: <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <h2>Prüfpunkte für später</h2>
        <ul>
          <li>Kontaktformular und Spam-Schutz.</li>
          <li>Terminbuchung.</li>
          <li>Messaging-Kanäle.</li>
          <li>Mentoring und bezahltes Coaching.</li>
          <li>Externe Dienste und Einbettungen.</li>
        </ul>
      </div>
    </Container>
  </section>
</PageLayout>
