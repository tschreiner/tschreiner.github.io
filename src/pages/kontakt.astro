---
import ContentLayout from '@layouts/ContentLayout.astro';
import { site } from '@lib/site';
---

<ContentLayout
  eyebrow="Kontakt"
  title="Kontakt aufnehmen"
  description="Am besten per E-Mail oder über berufliche Netzwerke. Ein Formular kommt erst dazu, wenn eine datenschutzarme Lösung klar ist."
>
  <section class="section pt-0">
    <div class="container-page grid gap-6 md:grid-cols-2">
      <div class="card">
        <h2 class="text-2xl font-semibold text-zinc-950">Direkt schreiben</h2>
        <p class="mt-3 leading-7 text-zinc-700">
          Für Projekte, Austausch oder kurze Rückfragen ist E-Mail der pragmatischste Weg.
        </p>
        <a class="button-primary mt-6" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
      <div class="card">
        <h2 class="text-2xl font-semibold text-zinc-950">Profile</h2>
        <div class="mt-5 grid gap-3">
          <a class="button-secondary justify-start" href={site.social.linkedin}>LinkedIn</a>
          <a class="button-secondary justify-start" href={site.social.github}>GitHub</a>
          <a class="button-secondary justify-start" href={site.social.xing}>Xing</a>
        </div>
      </div>
      <div class="card md:col-span-2">
        <h2 class="text-2xl font-semibold text-zinc-950">Kontaktformular</h2>
        <p class="mt-3 leading-7 text-zinc-700">
          Platzhalter: Ein Formular wird erst umgesetzt, wenn Hosting, Spam-Schutz und Verarbeitung ohne unnötiges Tracking
          geklärt sind. Bis dahin bleibt die Kontaktaufnahme bewusst simpel.
        </p>
      </div>
    </div>
  </section>
</ContentLayout>
