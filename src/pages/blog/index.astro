---
import BlogCard from '@components/BlogCard.astro';
import Container from '@components/Container.astro';
import TechTag from '@components/TechTag.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { byPubDateDesc, visiblePosts } from '@lib/content';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter(visiblePosts).sort(byPubDateDesc);
const categories = ['Tech', 'DevOps', 'Automation', 'AI Tools', 'Webprojekte', 'Personal Notes'];
---

<PageLayout
  eyebrow="Blog"
  title="Notizen zu DevOps, Netzwerkdaten und technischen Projekten."
  description="Praxisnahe Gedanken zu Automatisierung, Infrastruktur, Webprojekten, AI-Tools und technischen Entscheidungen."
>
  <section class="section section-after-header">
    <Container>
      {posts.length > 0 ? (
        <>
          <div class="mb-8" aria-label="Themen">
            <p class="meta-label mb-3">Themen</p>
            <div class="flex flex-wrap gap-2">
              {
                categories.map((category) => <TechTag label={category} />)
              }
            </div>
          </div>
          <div class="grid gap-5 md:grid-cols-3">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
        </>
      ) : (
        <div class="surface-card max-w-2xl">
          <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Noch keine veröffentlichten Artikel.</h2>
          <p class="mt-3 leading-7 text-[color:var(--muted)]">
            Sobald erste Beiträge live sind, erscheinen hier kompakte, praxisnahe Notizen zu DevOps,
            Netzwerkautomatisierung, Webprojekten und technischen Entscheidungen.
          </p>
        </div>
      )}
    </Container>
  </section>
</PageLayout>
