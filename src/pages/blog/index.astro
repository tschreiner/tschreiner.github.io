---
import BlogCard from '@components/BlogCard.astro';
import ContentLayout from '@layouts/ContentLayout.astro';
import { byDateDesc, isVisiblePost } from '@lib/content';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter(isVisiblePost).sort(byDateDesc);
---

<ContentLayout
  eyebrow="Blog"
  title="Notizen zu DevOps, Netzwerkdaten und Relaunches."
  description="Ein MDX-Blog mit Kategorien, Tags, Datum, Lesedauer, SEO-Metadaten, RSS und Draft-Handling."
>
  <section class="section pt-0">
    <div class="container-page">
      {posts.length > 0 ? (
        <div class="grid gap-5 md:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <div class="card max-w-2xl">
          <h2 class="text-2xl font-semibold text-zinc-950">Artikel sind in Vorbereitung.</h2>
          <p class="mt-3 leading-7 text-zinc-700">
            Die ersten Entwürfe liegen als Drafts im Content-System. Sie werden erst veröffentlicht, wenn Inhalt und Ton fertig sind.
          </p>
        </div>
      )}
    </div>
  </section>
</ContentLayout>
