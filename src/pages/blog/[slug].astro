---
import Container from '@components/Container.astro';
import TechTag from '@components/TechTag.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { formatDate, visiblePosts } from '@lib/content';
import { canonicalUrl as toCanonicalUrl, defaultSeoImage, defaultSeoImageAlt, imageUrl } from '@lib/seo';
import { site } from '@lib/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(visiblePosts);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const showDraftBadge = import.meta.env.DEV && post.data.draft;
const canonical = `/blog/${post.id}/`;
const postUrl = toCanonicalUrl(canonical);
const postImage = post.data.ogImage ?? defaultSeoImage;
const postImageAlt = post.data.ogImage
  ? `Open-Graph-Bild zum Blogartikel ${post.data.title}`
  : defaultSeoImageAlt;
const postImageUrl = imageUrl(postImage);
const postDescription = post.data.seo?.description ?? post.data.description;
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const keywords = Array.from(new Set(post.data.tags.filter(Boolean)));
const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: postDescription,
  datePublished: publishedTime,
  dateModified: modifiedTime,
  url: postUrl,
  author: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
  ...(postImageUrl ? { image: postImageUrl } : {}),
  ...(keywords.length > 0 ? { keywords } : {}),
};
---

<PageLayout
  eyebrow="Blog"
  title={post.data.title}
  description={post.data.description}
  tags={[post.data.category, post.data.readingTime, ...post.data.tags.slice(0, 2)]}
  seoTitle={post.data.seo?.title}
  seoDescription={post.data.seo?.description}
  canonical={canonical}
  image={postImage}
  imageAlt={postImageAlt}
  noindex={post.data.draft}
  type="article"
  jsonLd={blogJsonLd}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
>
  <article class="section section-after-header">
    <Container>
      <div class="surface-card prose-site">
        <div class="not-prose flex flex-wrap gap-2 text-sm text-[color:var(--sky-strong)]">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>{post.data.readingTime}</span>
          <TechTag label={post.data.category} />
          {showDraftBadge && <TechTag label="Entwurf" tone="warm" />}
        </div>
        <Content />
        <div class="not-prose mt-10 flex flex-wrap gap-2 border-t border-[color:var(--line)] pt-6">
          {post.data.tags.map((tag) => <TechTag label={`#${tag}`} />)}
        </div>
      </div>
    </Container>
  </article>
</PageLayout>
