---
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@lib/site';
---

<PageLayout
  eyebrow="Separates Projekt"
  title="Dating-Profil-Mentoring für introvertierte Nerds"
  description="Separate Brückenseite zu einem kleinen Mentoring-Nebenprojekt rund um Dating-Profile, bewusst getrennt vom technischen Schwerpunkt dieser Website."
>
  <section class="section pt-0">
    <Container class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-card prose-site">
        <p>
          Viele Dating-Profile scheitern nicht daran, dass jemand uninteressant ist. Sie scheitern daran, dass gute Eigenschaften
          nicht sichtbar werden: Humor, Verlässlichkeit, Neugier, Ruhe, Haltung.
        </p>
        <p>
          Genau dort setzt dieses separate Projekt an: respektvoll, ehrlich und ohne künstliche Rolle. Es richtet sich an
          introvertierte, analytische Männer, die auf Dating-Apps klarer kommunizieren wollen und dabei sie selbst bleiben möchten.
        </p>
        <p>
          Diese Seite bleibt bewusst eine Bridge. Das Thema steht getrennt neben der technischen Hauptpositionierung, und auf
          teddschreiner.de bleibt der berufliche Fokus klar bei DevOps, Projekten und technischer Arbeit.
        </p>
      </div>
      <aside class="surface-card h-fit">
        <h2 class="text-2xl font-semibold text-[color:var(--ink)]">Interesse?</h2>
        <p class="mt-3 leading-7 text-[color:var(--muted)]">
          Für erste Gespräche oder Rückfragen reicht eine kurze Nachricht.
        </p>
        <div class="mt-6 grid gap-3">
          <a class="button-primary" href={`mailto:${site.email}?subject=Interesse%20am%20Dating-Profil-Mentoring`}>
            Interesse melden
          </a>
          <a class="button-secondary" href={`mailto:${site.email}?subject=Kostenloses%20Erstgespraech%20anfragen`}>
            Kostenloses Erstgespräch anfragen
          </a>
          <a class="button-secondary" href={`mailto:${site.email}`}>Nachricht schreiben</a>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section pt-0">
    <Container>
      <ContactPanel />
    </Container>
  </section>
</PageLayout>
