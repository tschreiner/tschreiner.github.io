---
import BlogCard from '@components/BlogCard.astro';
import BridgeCard from '@components/BridgeCard.astro';
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TimelineItem from '@components/TimelineItem.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { byExperienceDateDesc, byProjectTitle, byPubDateDesc, visiblePosts } from '@lib/content';
import { site, skillClusters } from '@lib/site';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).filter((project) => project.data.featured).sort(byProjectTitle);
const posts = (await getCollection('blog')).filter(visiblePosts).sort(byPubDateDesc).slice(0, 3);
const experience = (await getCollection('experience')).sort(byExperienceDateDesc).slice(0, 2);
---

<BaseLayout title={site.title} description={site.description}>
  <Hero />

  <section class="section bg-white">
    <Container class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Kurzprofil / Status</p>
        <h2 class="section-title">Aktuell: DevOps, Netzwerkdaten und Automatisierung.</h2>
        <p class="section-copy">
          Ich arbeite an den Stellen, an denen Infrastruktur, Datenqualität und wiederholbare Abläufe zusammenkommen.
          Besonders spannend: Network Source of Truth, Netzwerkautomation und Labs, die technische Entscheidungen testbar machen.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          ['Fokus', 'Network Source of Truth, i-doit und Automatisierung'],
          ['Arbeitsweise', 'Pragmatisch, dokumentiert, risiko- und betriebsbewusst'],
          ['Nebenbei', 'Web-/AI-Projekte und kleine Systeme, die Alltag vereinfachen'],
          ['Schreibtischnotiz', 'Nicht jede gute Lösung braucht mehr Komplexität. Manchmal nur bessere Daten.'],
        ].map(([title, text]) => (
          <article class="surface-card">
            <h3 class="font-semibold text-zinc-950">{title}</h3>
            <p class="mt-3 text-sm leading-7 text-zinc-600">{text}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Featured Projects</p>
          <h2 class="section-title">Ausgewählte Arbeiten aus Infrastruktur und Automation.</h2>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/projects/">Alle Projekte</a>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>

  <section class="section bg-zinc-950 text-white">
    <Container class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
      <div>
        <p class="eyebrow text-teal-200">Skills / Expertise</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">Technische Tiefe, aber bitte wartbar.</h2>
        <p class="mt-5 leading-8 text-zinc-300">
          Die alten Skills wurden aus dem CV-Rohmaterial neu gruppiert: weniger Listenfriedhof, mehr erkennbare Arbeitsfelder.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {skillClusters.map((cluster) => <SkillCluster {...cluster} dark />)}
      </div>
    </Container>
  </section>

  <section class="section bg-white">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Latest Writing</p>
          <h2 class="section-title">Notizen und Entwürfe aus Technik, Projekten und Praxis.</h2>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/blog/">Zum Blog</a>
      </div>
      {posts.length > 0 ? (
        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <div class="surface-card mt-8 max-w-2xl">
          <h3 class="text-xl font-semibold text-zinc-950">Artikel sind in Vorbereitung.</h3>
          <p class="mt-3 leading-7 text-zinc-700">
            Die ersten Blogentwürfe liegen im Content-System und werden veröffentlicht, sobald Inhalt und Ton sitzen.
          </p>
        </div>
      )}
    </Container>
  </section>

  <section class="section">
    <Container>
      <p class="eyebrow">Career Snapshot</p>
      <h2 class="section-title">Der rote Faden: Systeme verstehen, ordnen und automatisieren.</h2>
      <div class="mt-8 grid gap-5">
        {experience.map((item) => <TimelineItem item={item} />)}
      </div>
    </Container>
  </section>

  <section class="section bg-white">
    <Container>
      <BridgeCard />
    </Container>
  </section>

  <section class="section">
    <Container>
      <ContactPanel />
    </Container>
  </section>
</BaseLayout>
