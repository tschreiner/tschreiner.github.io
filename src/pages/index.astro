---
import BlogCard from '@components/BlogCard.astro';
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TimelineItem from '@components/TimelineItem.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { byExperienceDateDesc, byProjectTitle, byPubDateDesc } from '@lib/content';
import { site, skillClusters } from '@lib/site';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).filter((project) => project.data.featured).sort(byProjectTitle);
const posts = (await getCollection('blog')).filter((post) => !post.data.draft).sort(byPubDateDesc).slice(0, 3);
const experience = (await getCollection('experience')).sort(byExperienceDateDesc).slice(0, 2);

const recruiterFitCards = [
  {
    title: 'DevOps & AWS Cloud',
    text: 'AWS-nahe Infrastruktur, Linux, Betriebsabläufe, Automatisierung und technische Plattformen.',
  },
  {
    title: 'CI/CD & Software Deployment',
    text: 'GitHub/GitLab Workflows, Deployment-Prozesse, Build-/Release-Abläufe und nachvollziehbare Änderungen.',
  },
  {
    title: 'Kubernetes & Platform Engineering',
    text: 'Containerisierte Umgebungen, Plattformlogik, Betriebsfähigkeit und wiederholbare technische Abläufe.',
  },
  {
    title: 'Automation & AI-assisted Software Engineering',
    text: 'Automatisierung von ITSM-, Infrastruktur- und Engineering-Prozessen, klassisch, skriptbasiert und AI-unterstützt.',
  },
  {
    title: 'Network Automation',
    text: 'Netzwerkdaten, Source of Truth, Ansible, REST APIs und Automatisierung im operativen Netzwerkbetrieb.',
  },
];
---

<BaseLayout title={site.title} description={site.description}>
  <Hero />

  <section class="section section-soft">
    <Container>
      <div class="max-w-3xl">
        <p class="eyebrow">Rollenprofil</p>
        <h2 class="section-title">Relevant für Rollen an der Schnittstelle von Cloud, Automation und Betrieb.</h2>
        <p class="section-copy">
          Ich bin besonders passend für Rollen, in denen Infrastruktur, Deployments und technische Prozesse
          zuverlässiger, nachvollziehbarer und stärker automatisiert werden sollen.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {recruiterFitCards.map((card) => (
          <article class="feature-card">
            <h3 class="text-lg font-semibold text-[color:var(--ink)]">{card.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">{card.text}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section section-dark">
    <Container class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div>
        <p class="eyebrow text-[color:var(--gold)]">Technische Schwerpunkte</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">
          Cloud-Infrastruktur, Deployment-Automation und Betrieb zusammen gedacht.
        </h2>
        <p class="mt-5 max-w-xl leading-8 text-[color:var(--warm-muted)]">
          Meine Arbeit verbindet AWS-nahe Infrastruktur, CI/CD, Kubernetes, ITSM-Workflows,
          Netzwerkautomatisierung und AI-unterstützte Engineering-Prozesse. Der gemeinsame Nenner:
          Systeme sollen verständlicher, zuverlässiger und besser automatisierbar werden.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {skillClusters.map((cluster) => <SkillCluster {...cluster} dark />)}
      </div>
    </Container>
  </section>

  <section class="section section-tight-bottom">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Case Studies</p>
          <h2 class="section-title">Ausgewählte Projektbeispiele aus Infrastruktur, Automatisierung und Netzwerkbetrieb.</h2>
          <p class="section-copy">
            Die Projektseiten sind bewusst anonymisiert. Sie zeigen Problem, Lösung, Technologien, Ergebnis und Lernpunkte,
            ohne vertrauliche Betriebsdetails offenzulegen.
          </p>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/projects/">Alle Projekte</a>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>

  <section class="section section-tight-y">
    <Container>
      <p class="eyebrow">Career Snapshot</p>
      <h2 class="section-title">Der rote Faden: Systeme verstehen, ordnen und automatisieren.</h2>
      <p class="section-copy">
        Der vollständige Lebenslauf bleibt verfügbar, aber auf der Startseite zählt vor allem der Zusammenhang:
        Entwicklung, Infrastruktur, Automatisierung und Betrieb wachsen hier zu einem klaren technischen Profil zusammen.
      </p>

      <ol class="timeline-list mt-10 max-w-4xl" aria-label="Berufserfahrung im Überblick">
        {experience.map((item) => <li><TimelineItem item={item} /></li>)}
      </ol>

      <div class="mt-5 pl-8 sm:pl-10">
        <a class="button-secondary" href="/cv/">Vollständigen CV öffnen</a>
      </div>
    </Container>
  </section>

  <section class="section section-tight-top">
    <Container>
      <ContactPanel />
    </Container>
  </section>

  {posts.length > 0 && (
    <section class="section section-soft">
      <Container>
        <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
          <div>
            <p class="eyebrow">Blog</p>
            <h2 class="section-title">Notizen zu DevOps, Netzwerkdaten und technischen Projekten.</h2>
            <p class="section-copy">
              Der Blog ist für Praxisnotizen gedacht: Entscheidungen, Learnings, kleine Experimente und technische
              Zusammenhänge, die nicht in eine klassische Projektseite passen.
            </p>
          </div>
          <a class="button-secondary self-start md:self-auto" href="/blog/">Zum Blog</a>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
