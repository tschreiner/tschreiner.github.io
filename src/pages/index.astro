---
import BlogCard from '@components/BlogCard.astro';
import BridgeCard from '@components/BridgeCard.astro';
import ContactPanel from '@components/ContactPanel.astro';
import Container from '@components/Container.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SkillCluster from '@components/SkillCluster.astro';
import TimelineItem from '@components/TimelineItem.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { byExperienceDateDesc, byProjectTitle, byPubDateDesc, visiblePosts } from '@lib/content';
import { site, skillClusters } from '@lib/site';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).filter((project) => project.data.featured).sort(byProjectTitle);
const posts = (await getCollection('blog')).filter(visiblePosts).sort(byPubDateDesc).slice(0, 3);
const experience = (await getCollection('experience')).sort(byExperienceDateDesc).slice(0, 2);
---

<BaseLayout title={site.title} description={site.description}>
  <Hero />

  <section class="section bg-[color:var(--surface)]">
    <Container class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Kurzprofil</p>
        <h2 class="section-title">Ich arbeite dort, wo Infrastruktur, Datenqualität und Automatisierung zusammenkommen.</h2>
        <p class="section-copy">
          Gute Automatisierung beginnt nicht beim Tool, sondern bei verständlichen Daten, klaren Abläufen und einem
          realistischen Blick auf den Betrieb. Genau an dieser Schnittstelle liegt mein Schwerpunkt.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          [
            [
              'Netzwerkdaten ordnen',
              'Source-of-Truth-Modelle, Inventarqualität und Beziehungen so strukturieren, dass daraus belastbare Abläufe entstehen.',
            ],
            [
              'Automation mit Guardrails',
              'Wiederkehrende Änderungen und Abfragen reproduzierbar machen, ohne Betriebsrisiken zu ignorieren.',
            ],
            [
              'Betrieb verständlich machen',
              'Dokumentation, Monitoring und Workflows so schneiden, dass technische Entscheidungen nachvollziehbar bleiben.',
            ],
            [
              'Labs und Projekte bauen',
              'Technische Annahmen in virtuellen Labs, Webprojekten und kleinen AI-Experimenten testbar machen.',
            ],
          ].map(([title, text]) => (
            <article class="surface-card">
              <h3 class="font-semibold text-[color:var(--ink)]">{title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{text}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Case Studies</p>
          <h2 class="section-title">Ausgewählte Arbeiten aus Netzwerkautomatisierung, Source of Truth und technischen Labs.</h2>
          <p class="section-copy">
            Die Projektseiten sind bewusst anonymisiert. Sie zeigen Problem, Lösung, Technologien, Ergebnis und Lernpunkte,
            ohne vertrauliche Betriebsdetails offenzulegen.
          </p>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/projects/">Alle Projekte</a>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Container>
  </section>

  <section class="section bg-[color:var(--graphite)] text-[#fff7ed]">
    <Container class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
      <div>
        <p class="eyebrow text-[#f0bf75]">Skills / Expertise</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight sm:text-4xl">
          Technische Tiefe, aber bitte wartbar.
        </h2>
        <p class="mt-5 leading-8 text-[#d8c8b4]">
          Meine Arbeit verbindet Infrastrukturpraxis mit sauberer Modellierung, nachvollziehbarer Automatisierung und
          pragmatischen Betriebsabläufen. Der gemeinsame Nenner: Systeme sollen verständlicher und zuverlässiger werden.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {skillClusters.map((cluster) => <SkillCluster {...cluster} dark />)}
      </div>
    </Container>
  </section>

  <section class="section bg-[color:var(--surface)]">
    <Container>
      <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Blog</p>
          <h2 class="section-title">Notizen zu DevOps, Netzwerkdaten und technischen Projekten.</h2>
          <p class="section-copy">
            Der Blog ist für Praxisnotizen gedacht: Entscheidungen, Learnings, kleine Experimente und technische
            Zusammenhänge, die nicht in eine klassische Projektseite passen.
          </p>
        </div>
        <a class="button-secondary self-start md:self-auto" href="/blog/">Zum Blog</a>
      </div>

      {posts.length > 0 ? (
        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <div class="surface-card mt-8 max-w-2xl">
          <h3 class="text-xl font-semibold text-[color:var(--ink)]">Artikel sind in Vorbereitung.</h3>
          <p class="mt-3 leading-7 text-[color:var(--muted)]">
            Der Blog startet mit kompakten, praxisnahen Notizen zu DevOps, Netzwerkautomatisierung, Webprojekten und
            technischen Entscheidungen.
          </p>
        </div>
      )}
    </Container>
  </section>

  <section class="section">
    <Container>
      <p class="eyebrow">Career Snapshot</p>
      <h2 class="section-title">Der rote Faden: Systeme verstehen, ordnen und automatisieren.</h2>
      <p class="section-copy">
        Der vollständige Lebenslauf bleibt verfügbar, aber auf der Startseite zählt vor allem der Zusammenhang:
        Entwicklung, Infrastruktur, Automatisierung und Betrieb wachsen hier zu einem klaren technischen Profil zusammen.
      </p>

      <div class="mt-8 grid gap-5">
        {experience.map((item) => <TimelineItem item={item} />)}
      </div>

      <div class="mt-8">
        <a class="button-secondary" href="/cv/">Vollständigen CV öffnen</a>
      </div>
    </Container>
  </section>

  <section class="section bg-[color:var(--surface)]">
    <Container>
      <BridgeCard />
    </Container>
  </section>

  <section class="section">
    <Container>
      <ContactPanel />
    </Container>
  </section>
</BaseLayout>
