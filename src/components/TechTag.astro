---
interface Props {
  label: string;
  tone?: 'default' | 'dark' | 'warm';
}

const { label, tone = 'default' } = Astro.props;
const toneClass =
  tone === 'dark'
    ? 'border-white/10 bg-white/10 text-[#f7ead9]'
    : tone === 'warm'
      ? 'border-[#d6b083] bg-[#fff1df] text-[color:var(--accent-dark)]'
      : 'border-[color:var(--line)] bg-[#f8efe3] text-[color:var(--muted)]';
---

<span class={`inline-flex items-center rounded-md border px-2.5 py-1 text-xs font-medium ${toneClass}`}>
  {label}
</span>
