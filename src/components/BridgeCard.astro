---
import { site } from '@lib/site';
---

<article class="rounded-lg border border-[color:var(--accent-soft)] bg-[color:var(--cream-strong)] p-6 sm:p-8">
  <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
    <div>
      <p class="eyebrow">Nebenprojekt</p>
      <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
        Bewusst getrennt von DevOps und Infrastruktur, aber mit derselben Arbeitsweise: beobachten, ordnen, verbessern.
      </p>
    </div>
    <div>
      <h2 class="text-2xl font-semibold leading-tight text-[color:var(--ink)]">Dating-Profil-Mentoring für introvertierte Nerds.</h2>
      <p class="mt-3 leading-7 text-[color:var(--muted)]">
        Ein separates Projekt in Vorbereitung: für introvertierte, analytische Männer, die auf Dating-Apps klarer,
        sympathischer und ehrlicher wirken wollen, ohne sich zu verstellen.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="button-primary" href="/mentoring/">Mehr erfahren</a>
        <a class="button-secondary" href={`mailto:${site.email}?subject=Interesse%20am%20Dating-Profil-Mentoring`}>
          Interesse vormerken
        </a>
      </div>
    </div>
  </div>
</article>
