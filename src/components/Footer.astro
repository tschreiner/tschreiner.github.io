---
import Container from '@components/Container.astro';
import { navigation, site } from '@lib/site';
---

<footer class="border-t border-[color:var(--line)] bg-[color:var(--surface)]">
  <Container class="grid gap-8 py-10 md:grid-cols-[1.25fr_0.9fr_0.9fr]">
    <div>
      <p class="font-semibold text-[color:var(--ink)]">{site.name}</p>
      <p class="mt-3 max-w-md text-sm leading-7 text-[color:var(--muted)]">
        DevOps, Netzwerkautomatisierung und Web-/AI-Projekte mit Sinn für robuste Systeme und klare Kommunikation.
      </p>
    </div>
    <div>
      <p class="text-sm font-semibold text-[color:var(--ink)]">Navigation</p>
      <div class="mt-3 grid gap-2 text-sm text-[color:var(--muted)]">
        {navigation.map((item) => <a class="hover:text-[color:var(--accent-dark)]" href={item.href}>{item.label}</a>)}
        <a class="hover:text-[color:var(--accent-dark)]" href="/mentoring/">Mentoring</a>
      </div>
    </div>
    <div>
      <p class="text-sm font-semibold text-[color:var(--ink)]">Kontakt & Legal</p>
      <div class="mt-3 grid gap-2 text-sm text-[color:var(--muted)]">
        <a class="hover:text-[color:var(--accent-dark)]" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="hover:text-[color:var(--accent-dark)]" href={site.social.linkedin}>LinkedIn</a>
        <a class="hover:text-[color:var(--accent-dark)]" href={site.social.github}>GitHub</a>
        <a class="hover:text-[color:var(--accent-dark)]" href={site.social.xing}>Xing</a>
        <a class="hover:text-[color:var(--accent-dark)]" href="/impressum/">Impressum</a>
        <a class="hover:text-[color:var(--accent-dark)]" href="/datenschutz/">Datenschutz</a>
        <a class="hover:text-[color:var(--accent-dark)]" href="/rss.xml">RSS</a>
      </div>
    </div>
  </Container>
  <div class="border-t border-[color:var(--line)] py-4">
    <Container class="text-sm text-[color:var(--muted)]">
      © {new Date().getFullYear()}{' '}{site.name}. Statisch gebaut, ohne Tracking-Skripte und ohne externe Webfonts.
    </Container>
  </div>
</footer>
