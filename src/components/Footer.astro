---
import Container from '@components/Container.astro';
import SocialIcon from '@components/SocialIcon.astro';
import { getLocaleFromPath, withLocalePath } from '@lib/i18n';
import { getNavigation, getSite } from '@lib/site';

const locale = getLocaleFromPath(Astro.url.pathname);
const navigation = getNavigation(locale);
const site = getSite(locale);
const copy = locale === 'de'
  ? {
      intro:
        'DevOps Engineer mit Fokus auf AWS Cloud, CI/CD, Automatisierung, Netzwerkbetrieb und AI-assisted Software Engineering.',
      nav: 'Navigation',
      legal: 'Kontakt & Legal',
      imprint: 'Impressum',
      privacy: 'Datenschutz',
      footer:
        'Statisch gebaut, mit zustimmungsbasierter Statistik und ohne externe Webfonts.',
    }
  : {
      intro:
        'DevOps Engineer focused on AWS Cloud, CI/CD, automation, network operations and AI-assisted software engineering.',
      nav: 'Navigation',
      legal: 'Contact & Legal',
      imprint: 'Legal Notice',
      privacy: 'Privacy Policy',
      footer:
        'Statically built, with consent-based analytics and without external webfonts.',
    };
---

<footer class="border-t border-black/10 bg-[color:var(--graphite)] text-[color:var(--warm-muted)]">
  <Container class="grid gap-10 py-12 md:grid-cols-[1.25fr_0.9fr_0.9fr]">
    <div>
      <p class="font-semibold text-[color:var(--warm-text)]">{site.name}</p>
      <p class="mt-3 max-w-md text-sm leading-7">
        {copy.intro}
      </p>
    </div>

    <nav aria-label="Footer Navigation">
      <p class="text-sm font-semibold text-[color:var(--warm-text)]">{copy.nav}</p>
      <ul class="mt-3 grid gap-2 text-sm">
        {navigation.map((item) => <li><a class="footer-link" href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <nav aria-label="Footer Kontakt und Rechtliches">
      <p class="text-sm font-semibold text-[color:var(--warm-text)]">{copy.legal}</p>
      <ul class="mt-3 grid gap-2 text-sm">
        <li>
          <a class="footer-link social-link" href={`mailto:${site.email}`}>
            <SocialIcon name="mail" />
            {site.email}
          </a>
        </li>
        <li>
          <a class="footer-link social-link" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="linkedin" />
            LinkedIn
          </a>
        </li>
        <li>
          <a class="footer-link social-link" href={site.social.xing} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="xing" />
            Xing
          </a>
        </li>
        <li>
          <a class="footer-link social-link" href={site.social.github} target="_blank" rel="noopener noreferrer">
            <SocialIcon name="github" />
            GitHub
          </a>
        </li>
        <li><a class="footer-link" href={withLocalePath(locale, '/impressum/')}>{copy.imprint}</a></li>
        <li><a class="footer-link" href={withLocalePath(locale, '/datenschutz/')}>{copy.privacy}</a></li>
      </ul>
    </nav>
  </Container>

  <div class="border-t border-white/10 py-4">
    <Container class="text-sm text-[color:var(--warm-muted)]">
      © {new Date().getFullYear()}{' '}{site.name}. {copy.footer}
    </Container>
  </div>
</footer>
