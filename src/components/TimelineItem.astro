---
import EmployerLogo from '@components/EmployerLogo.astro';
import TechTag from '@components/TechTag.astro';
import type { Locale } from '@lib/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'experience'>;
}

const { item } = Astro.props;
const locale = item.data.locale as Locale;
const formatMonthYear = (value?: string) => {
  if (!value) return '';

  const [year, month] = value.split('-');
  if (/^\d{4}$/.test(year) && /^\d{1,2}$/.test(month ?? '')) {
    return `${month.padStart(2, '0')}.${year}`;
  }

  return value;
};

const start = formatMonthYear(item.data.startDate);
const end = item.data.current ? (locale === 'de' ? 'heute' : 'present') : formatMonthYear(item.data.endDate);
const dateLabel = end ? `${start} – ${end}` : start;
---

<article class="timeline-item">
  <div class="timeline-card surface-card">
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex min-w-0 items-start gap-3">
        <EmployerLogo company={item.data.company} />
        <div class="min-w-0">
          <h3 class="text-xl font-semibold text-[color:var(--ink)]">{item.data.role}</h3>
          <p class="mt-1 text-sm font-medium text-[color:var(--accent-dark)]">{item.data.company} · {item.data.location}</p>
        </div>
      </div>
      <p class="w-fit rounded-md border border-[color:var(--surface-cool-line)] bg-[color:var(--surface-cool)] px-3 py-1 text-sm font-semibold text-[color:var(--sky-strong)]">
        {dateLabel}
      </p>
    </div>
    <p class="mt-4 leading-7 text-[color:var(--muted)]">{item.data.summary}</p>
    <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-7 text-[color:var(--muted-strong)] marker:text-[color:var(--accent)]">
      {item.data.highlights.map((highlight) => <li>{highlight}</li>)}
    </ul>
    <div class="mt-5 flex flex-wrap gap-2">
      {item.data.technologies.map((tech) => <TechTag label={tech} />)}
    </div>
  </div>
</article>
