---
import TechTag from '@components/TechTag.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'experience'>;
}

const { item } = Astro.props;
const end = item.data.current ? 'Heute' : item.data.endDate;
---

<article class="relative border-l border-[color:var(--line)] pl-6">
  <span class="absolute -left-[7px] top-1.5 size-3 rounded-full border-2 border-[color:var(--surface)] bg-[color:var(--accent)] shadow-sm" aria-hidden="true"></span>
  <div class="surface-card">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
      <div>
        <h3 class="text-xl font-semibold text-[color:var(--ink)]">{item.data.role}</h3>
        <p class="mt-1 text-sm font-medium text-[color:var(--accent-dark)]">{item.data.company} · {item.data.location}</p>
      </div>
      <p class="text-sm text-[color:var(--sky-strong)]">{item.data.startDate} - {end}</p>
    </div>
    <p class="mt-4 leading-7 text-[color:var(--muted)]">{item.data.summary}</p>
    <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-7 text-[color:var(--muted-strong)] marker:text-[color:var(--accent)]">
      {item.data.highlights.map((highlight) => <li>{highlight}</li>)}
    </ul>
    <div class="mt-5 flex flex-wrap gap-2">
      {item.data.technologies.map((tech) => <TechTag label={tech} />)}
    </div>
  </div>
</article>
