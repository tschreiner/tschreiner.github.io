---
import TechTag from '@components/TechTag.astro';
import { readingLabel } from '@lib/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const postHref = `/blog/${post.id}/`;
---

<article class="h-full">
  <a
    class="blog-card surface-card interactive-card flex h-full flex-col no-underline"
    href={postHref}
    aria-label={`Artikel ${post.data.title} lesen`}
  >
    <div class="flex flex-1 flex-col p-6 sm:p-7">
      <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
        <span class="meta-label text-[color:var(--sky-strong)]">{post.data.category}</span>
        <time class="meta-note" datetime={post.data.pubDate.toISOString()}>{readingLabel(post)}</time>
      </div>
      <h3 class="mt-6 text-2xl font-semibold leading-tight text-[color:var(--ink)]">
        {post.data.title}
      </h3>
      <p class="mt-4 flex-1 leading-7 text-[color:var(--muted)]">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.draft && <TechTag label="Entwurf" tone="warm" />}
        {post.data.tags.slice(0, 3).map((tag) => <TechTag label={tag} />)}
      </div>
      <span class="card-cta mt-7 self-start">
        Artikel lesen
        <span class="card-cta-icon" aria-hidden="true">-&gt;</span>
      </span>
    </div>
  </a>
</article>
