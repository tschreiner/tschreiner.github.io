---
import TechTag from '@components/TechTag.astro';
import { readingLabel } from '@lib/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="surface-card interactive-card h-full">
  <div class="flex flex-wrap items-center gap-2 text-xs text-[color:var(--sky)]">
    <time datetime={post.data.pubDate.toISOString()}>{readingLabel(post)}</time>
    {post.data.draft && <TechTag label="Draft" tone="warm" />}
  </div>
  <h3 class="mt-4 text-xl font-semibold text-[color:var(--ink)]">
    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
  </h3>
  <p class="mt-3 leading-7 text-[color:var(--muted)]">{post.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    <TechTag label={post.data.category} />
    {post.data.tags.slice(0, 3).map((tag) => <TechTag label={tag} />)}
  </div>
</article>
