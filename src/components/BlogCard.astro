---
import TechTag from '@components/TechTag.astro';
import { readingLabel } from '@lib/content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="blog-card surface-card interactive-card flex h-full flex-col">
  <div class="flex flex-1 flex-col p-6">
    <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
      <span class="font-semibold uppercase tracking-[0.14em] text-[color:var(--sky)]">{post.data.category}</span>
      <time class="text-[color:var(--muted)]" datetime={post.data.pubDate.toISOString()}>{readingLabel(post)}</time>
    </div>
    <h3 class="mt-5 text-xl font-semibold leading-snug text-[color:var(--ink)]">
      <a href={`/blog/${post.id}/`}>{post.data.title}</a>
    </h3>
    <p class="mt-3 flex-1 leading-7 text-[color:var(--muted)]">{post.data.description}</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {post.data.draft && <TechTag label="Draft" tone="warm" />}
      {post.data.tags.slice(0, 3).map((tag) => <TechTag label={tag} />)}
    </div>
    <a class="mt-6 inline-flex items-center self-start text-sm font-semibold text-[color:var(--accent-dark)] hover:text-[color:var(--ink)]" href={`/blog/${post.id}/`}>
      Artikel lesen
      <span class="ml-2" aria-hidden="true">-&gt;</span>
    </a>
  </div>
</article>
