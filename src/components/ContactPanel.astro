---
import { site } from '@lib/site';
---

<section class="surface-card">
  <p class="eyebrow">Kontakt</p>
  <h2 class="mt-3 max-w-2xl text-3xl font-semibold leading-tight text-[color:var(--ink)]">
    Kontakt für DevOps-, Cloud-, Automation- und AI-Software-Engineering-Rollen.
  </h2>
  <p class="mt-4 leading-7 text-[color:var(--muted-strong)]">
    Relevant sind Anfragen zu AWS Cloud, CI/CD, Kubernetes, Infrastrukturautomatisierung, Software Deployments,
    ITSM-Prozessen, Netzwerkautomatisierung und AI-gestütztem Software Engineering.
  </p>
  <div class="mt-7 flex flex-col gap-3 sm:flex-row">
    <a class="button-primary" href={`mailto:${site.email}`}>{site.email}</a>
    <a class="button-secondary" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a class="button-secondary" href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
  </div>
</section>
