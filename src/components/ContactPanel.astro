---
import { site } from '@lib/site';
---

<section class="surface-card">
  <p class="eyebrow">Kontakt</p>
  <h2 class="mt-3 max-w-2xl text-3xl font-semibold leading-tight text-[color:var(--ink)]">
    Lass uns über Infrastruktur, Automation oder ein passendes Projekt sprechen.
  </h2>
  <p class="mt-4 leading-7 text-[color:var(--muted-strong)]">
    Am einfachsten per E-Mail oder über berufliche Netzwerke, wenn es um DevOps, Netzwerkautomatisierung oder verwandte
    technische Themen geht.
  </p>
  <div class="mt-7 flex flex-col gap-3 sm:flex-row">
    <a class="button-primary" href={`mailto:${site.email}`}>{site.email}</a>
    <a class="button-secondary" href={site.social.linkedin}>LinkedIn</a>
    <a class="button-secondary" href={site.social.github}>GitHub</a>
  </div>
</section>
