---
import SocialIcon from '@components/SocialIcon.astro';
import { site } from '@lib/site';
---

<section class="surface-card">
  <p class="eyebrow">Kontakt</p>
  <h2 class="mt-3 max-w-2xl text-3xl font-semibold leading-tight text-[color:var(--ink)]">
    Kontakt für DevOps-, Cloud-, Automation- und AI-assisted Software Engineering-Rollen.
  </h2>
  <p class="mt-4 leading-7 text-[color:var(--muted-strong)]">
    Relevant sind Anfragen zu AWS Cloud, CI/CD, Kubernetes, Infrastrukturautomatisierung, Software Deployments,
    ITSM-Prozessen, Netzwerkautomatisierung und AI-gestütztem Software Engineering.
  </p>

  <form class="contact-form mt-8" action="/api/contact" method="post" data-contact-form>
    <label class="form-honeypot">
      Website
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>

    <div class="form-grid">
      <label class="form-field">
        <span>Name</span>
        <input name="name" type="text" autocomplete="name" maxlength="120" required />
      </label>
      <label class="form-field">
        <span>E-Mail</span>
        <input name="email" type="email" autocomplete="email" maxlength="180" required />
      </label>
    </div>

    <div class="form-grid">
      <label class="form-field">
        <span>Organisation</span>
        <input name="organization" type="text" autocomplete="organization" maxlength="160" />
      </label>
      <label class="form-field">
        <span>Betreff</span>
        <input name="subject" type="text" maxlength="180" required />
      </label>
    </div>

    <label class="form-field">
      <span>Nachricht</span>
      <textarea name="message" rows="7" maxlength="4000" required></textarea>
    </label>

    <label class="form-checkbox">
      <input type="checkbox" name="privacy" value="accepted" required />
      <span>
        Ich bin einverstanden, dass meine Angaben zur Bearbeitung der Anfrage per E-Mail verarbeitet werden.
        {' '}<a class="form-inline-link" href="/datenschutz/">Datenschutzerklärung</a>
      </span>
    </label>

    <p class="form-status" data-contact-status role="status" aria-live="polite" tabindex="-1"></p>

    <div class="form-actions">
      <button class="button-primary gap-2" type="submit">
        <SocialIcon name="mail" />
        Anfrage senden
      </button>
      <button class="button-secondary gap-2" type="button" data-copy-email={site.email} aria-label="E-Mail-Adresse kopieren">
        <SocialIcon name="mail" />
        <span data-copy-label>E-Mail kopieren</span>
      </button>
      <a class="button-secondary gap-2" href={`mailto:${site.email}`}>
        <SocialIcon name="mail" />
        E-Mail direkt
      </a>
      <a class="button-secondary gap-2" href={site.social.linkedin} target="_blank" rel="noopener noreferrer">
        <SocialIcon name="linkedin" />
        LinkedIn
      </a>
    </div>
  </form>
</section>

<script>
  const contactForms = document.querySelectorAll<HTMLFormElement>('[data-contact-form]');
  type TrackingWindow = Window & {
    trackSiteEvent?: (name: string, params?: Record<string, string | number | boolean>) => void;
  };
  const trackingWindow = window as TrackingWindow;

  contactForms.forEach((form) => {
    const status = form.querySelector<HTMLElement>('[data-contact-status]');
    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const copyButton = form.querySelector<HTMLButtonElement>('[data-copy-email]');
    const copyLabel = copyButton?.querySelector<HTMLElement>('[data-copy-label]');
    let copyResetTimer: number | undefined;
    const copyText = async (text: string) => {
      if (!navigator.clipboard?.writeText) {
        throw new Error('clipboard unavailable');
      }

      await navigator.clipboard.writeText(text);
    };

    copyButton?.addEventListener('click', async () => {
      const email = copyButton.dataset.copyEmail;
      if (!email || !copyLabel) return;

      const defaultLabel = copyLabel.dataset.defaultLabel || copyLabel.textContent || 'E-Mail kopieren';
      copyLabel.dataset.defaultLabel = defaultLabel;
      window.clearTimeout(copyResetTimer);

      try {
        await copyText(email);
        copyLabel.textContent = 'Kopiert';
        copyButton.dataset.state = 'success';
        copyButton.setAttribute('aria-label', 'E-Mail-Adresse kopiert');
        trackingWindow.trackSiteEvent?.('email_copy', { location: 'contact_form' });
      } catch {
        copyLabel.textContent = 'Nicht kopiert';
        copyButton.dataset.state = 'error';
        copyButton.setAttribute('aria-label', 'E-Mail-Adresse konnte nicht kopiert werden');
      }

      copyResetTimer = window.setTimeout(() => {
        copyLabel.textContent = defaultLabel;
        copyButton.removeAttribute('data-state');
        copyButton.setAttribute('aria-label', 'E-Mail-Adresse kopieren');
      }, 1800);
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!status || !submitButton) {
        form.submit();
        return;
      }

      status.textContent = 'Die Anfrage wird gesendet.';
      status.dataset.state = 'pending';
      submitButton.disabled = true;
      trackingWindow.trackSiteEvent?.('contact_form_submit', { form_name: 'contact' });

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json',
          },
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok || !result.ok) {
          throw new Error(result.message || 'Die Anfrage konnte nicht gesendet werden.');
        }

        form.reset();
        status.textContent = result.message || 'Danke, die Anfrage wurde gesendet. Ich melde mich zeitnah zurück.';
        status.dataset.state = 'success';
        trackingWindow.trackSiteEvent?.('generate_lead', {
          form_name: 'contact',
          lead_source: 'website_contact_form',
        });
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : 'Die Anfrage konnte nicht gesendet werden.';
        status.dataset.state = 'error';
        trackingWindow.trackSiteEvent?.('contact_form_error', { form_name: 'contact' });
      } finally {
        submitButton.disabled = false;
      }
    });
  });
</script>
