---
import Container from '@components/Container.astro';
import { navigation, site } from '@lib/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
const isContact = (href: string) => href === '/contact/';
---

<header class="sticky top-0 z-50 border-b border-[color:var(--line)] bg-[color:var(--surface)]/90 shadow-sm backdrop-blur">
  <a
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:border focus:border-[color:var(--line)] focus:bg-[color:var(--surface)] focus:px-4 focus:py-2 focus:font-semibold focus:text-[color:var(--ink)] focus:shadow-lg"
    href="#content"
  >
    Zum Inhalt springen
  </a>

  <Container class="flex min-h-18 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 rounded-md font-semibold text-[color:var(--ink)]" aria-label="Startseite">
      <span class="grid size-10 place-items-center rounded-md border border-[color:var(--graphite)] bg-[color:var(--graphite)] text-sm text-[color:var(--warm-text)] shadow-sm">
        TS
      </span>
      <span class="tracking-wide">{site.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {
        navigation.map((item) => {
          const active = isActive(item.href);
          const className = isContact(item.href)
            ? 'button-primary ml-1'
            : active
              ? 'button-ghost is-active'
              : 'button-ghost';

          return (
            <a class={className} href={item.href} aria-current={active ? 'page' : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <details class="relative md:hidden">
      <summary class="mobile-menu-button cursor-pointer list-none">
        <span class="mobile-menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        Menü
      </summary>

      <nav
        class="absolute right-0 z-20 mt-3 grid w-60 max-w-[calc(100vw-2.5rem)] gap-1 overflow-auto rounded-lg border border-[color:var(--line)] bg-[color:var(--surface)] p-2 shadow-xl"
        aria-label="Mobile Navigation"
      >
        {
          navigation.map((item) => {
            const active = isActive(item.href);
            const className = isContact(item.href)
              ? 'mt-1 rounded-md bg-[color:var(--graphite)] px-3 py-2 text-sm font-semibold text-white hover:bg-[color:var(--accent-dark)]'
              : active
                ? 'rounded-md bg-[color:var(--paper)] px-3 py-2 text-sm font-semibold text-[color:var(--accent-dark)]'
                : 'rounded-md px-3 py-2 text-sm font-semibold text-[color:var(--ink)] hover:bg-[color:var(--paper)]';

            return (
              <a class={className} href={item.href} aria-current={active ? 'page' : undefined}>
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </details>
  </Container>
</header>
