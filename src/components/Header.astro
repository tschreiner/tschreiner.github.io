---
import Container from '@components/Container.astro';
import { navigation, site } from '@lib/site';
---

<header class="sticky top-0 z-50 border-b border-[color:var(--line)] bg-[color:var(--surface)]/88 backdrop-blur">
  <a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[color:var(--surface)] focus:px-4 focus:py-2" href="#content">
    Zum Inhalt springen
  </a>
  <Container class="flex min-h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 font-semibold text-[color:var(--ink)]" aria-label="Startseite">
      <span class="grid size-9 place-items-center rounded-md bg-[color:var(--graphite)] text-sm text-[#f7ead9]">TS</span>
      <span>{site.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {navigation.map((item) => <a class="button-ghost" href={item.href}>{item.label}</a>)}
    </nav>

    <details class="relative md:hidden">
      <summary class="button-secondary cursor-pointer list-none">Menü</summary>
      <nav class="absolute right-0 mt-3 grid w-52 gap-1 rounded-lg border border-[color:var(--line)] bg-[color:var(--surface)] p-2 shadow-xl" aria-label="Mobile Navigation">
        {navigation.map((item) => (
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-[color:var(--ink)] hover:bg-[#f3eadf]" href={item.href}>{item.label}</a>
        ))}
      </nav>
    </details>
  </Container>
</header>
