---
interface Props {
  title?: string;
  tone?: 'info' | 'warning';
}

const { title, tone = 'info' } = Astro.props;
const className =
  tone === 'warning'
    ? 'border-amber-200 bg-amber-50 text-amber-950'
    : 'border-teal-200 bg-teal-50 text-teal-950';
---

<aside class={`my-6 rounded-lg border p-4 ${className}`}>
  {title && <p class="font-semibold">{title}</p>}
  <div class="mt-2 leading-7">
    <slot />
  </div>
</aside>
