---
interface Props {
  title?: string;
  tone?: 'info' | 'warning';
}

const { title, tone = 'info' } = Astro.props;
const className =
  tone === 'warning'
    ? 'border-[color:var(--accent-soft)] bg-[color:var(--cream-strong)] text-[color:var(--accent-dark)]'
    : 'border-[color:var(--surface-cool-line)] bg-[color:var(--surface-cool)] text-[color:var(--graphite)]';
---

<aside class={`my-6 rounded-lg border p-4 ${className}`}>
  {title && <p class="font-semibold">{title}</p>}
  <div class="mt-2 leading-7">
    <slot />
  </div>
</aside>
