---
interface Props {
  title?: string;
  tone?: 'info' | 'warning';
}

const { title, tone = 'info' } = Astro.props;
const className =
  tone === 'warning'
    ? 'border-[#d6b083] bg-[#fff1df] text-[color:var(--accent-dark)]'
    : 'border-[#b9c9d1] bg-[#edf3f5] text-[color:var(--graphite)]';
---

<aside class={`my-6 rounded-lg border p-4 ${className}`}>
  {title && <p class="font-semibold">{title}</p>}
  <div class="mt-2 leading-7">
    <slot />
  </div>
</aside>
