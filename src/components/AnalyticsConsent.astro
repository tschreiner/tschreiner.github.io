---
import { googleAnalyticsId } from '@lib/analytics';
---

<div class="cookie-consent" data-cookie-consent hidden>
  <div class="cookie-consent-panel" role="dialog" aria-modal="false" aria-labelledby="cookie-consent-title">
    <div>
      <p class="eyebrow">Datenschutz</p>
      <h2 id="cookie-consent-title" class="mt-2 text-xl font-semibold text-[color:var(--ink)]">
        Statistik-Cookies erlauben?
      </h2>
      <p class="mt-3 text-sm leading-6 text-[color:var(--muted-strong)]">
        Ich nutze Google Analytics nur mit deiner Zustimmung, um zu verstehen, welche Inhalte hilfreich sind.
        Ohne Zustimmung werden keine Analytics-Cookies gesetzt und keine Analytics-Daten an Google gesendet.
      </p>
    </div>

    <label class="cookie-option">
      <input type="checkbox" data-cookie-statistics />
      <span>
        <strong>Statistik</strong>
        <small>Google Analytics für Seitenaufrufe und Interaktionen aktivieren.</small>
      </span>
    </label>

    <div class="cookie-actions">
      <button class="button-primary" type="button" data-cookie-accept>Alle akzeptieren</button>
      <button class="button-secondary" type="button" data-cookie-save>Auswahl speichern</button>
      <button class="button-ghost" type="button" data-cookie-reject>Ablehnen</button>
      <a class="text-link" href="/datenschutz/">Datenschutz</a>
    </div>
  </div>
</div>

<button class="cookie-settings-button" type="button" data-cookie-settings hidden>Cookie-Einstellungen</button>

<script is:inline define:vars={{ googleAnalyticsId }}>
  const consentKey = 'ts_cookie_consent_v1';
  const gaCookieNames = ['_ga', `_ga_${googleAnalyticsId.replace('G-', '')}`];

  const consentBanner = document.querySelector('[data-cookie-consent]');
  const settingsButton = document.querySelector('[data-cookie-settings]');
  const statisticsCheckbox = document.querySelector('[data-cookie-statistics]');
  const acceptButton = document.querySelector('[data-cookie-accept]');
  const rejectButton = document.querySelector('[data-cookie-reject]');
  const saveButton = document.querySelector('[data-cookie-save]');

  const trackingWindow = window;
  let analyticsLoaded = false;

  const readConsent = () => {
    try {
      const value = window.localStorage.getItem(consentKey);
      const parsed = value ? JSON.parse(value) : null;
      return parsed && typeof parsed.analytics === 'boolean' ? parsed : null;
    } catch {
      return null;
    }
  };

  const writeConsent = (analytics) => {
    const state = {
      analytics,
      updatedAt: new Date().toISOString(),
    };

    window.localStorage.setItem(consentKey, JSON.stringify(state));
    return state;
  };

  const deleteCookie = (name) => {
    const hostParts = window.location.hostname.split('.');
    const domains = [
      window.location.hostname,
      hostParts.length > 2 ? `.${hostParts.slice(-2).join('.')}` : `.${window.location.hostname}`,
    ];

    ['', ...domains].forEach((domain) => {
      document.cookie = `${name}=; Max-Age=0; path=/; SameSite=Lax${domain ? `; domain=${domain}` : ''}`;
    });
  };

  const clearAnalyticsCookies = () => {
    gaCookieNames.forEach(deleteCookie);
  };

  const updateConsentMode = (analytics) => {
    trackingWindow.gtag?.('consent', 'update', {
      analytics_storage: analytics ? 'granted' : 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
    });
  };

  const loadAnalytics = () => {
    if (analyticsLoaded || document.querySelector(`[src*="googletagmanager.com/gtag/js?id=${googleAnalyticsId}"]`)) {
      analyticsLoaded = true;
      return;
    }

    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`;
    document.head.append(script);

    trackingWindow.gtag?.('js', new Date());
    trackingWindow.gtag?.('config', googleAnalyticsId, {
      anonymize_ip: true,
      send_page_view: true,
    });
    analyticsLoaded = true;
  };

  const applyConsent = (state) => {
    const analytics = Boolean(state?.analytics);
    updateConsentMode(analytics);

    if (analytics) {
      loadAnalytics();
    } else {
      clearAnalyticsCookies();
    }

    if (settingsButton) settingsButton.hidden = false;
    if (consentBanner) consentBanner.hidden = state !== null;
    if (statisticsCheckbox) statisticsCheckbox.checked = analytics;
  };

  const saveConsent = (analytics) => {
    const state = writeConsent(analytics);
    applyConsent(state);
  };

  trackingWindow['trackSiteEvent'] = (name, params = {}) => {
    const state = readConsent();
    if (!state?.analytics || !trackingWindow.gtag) return;

    trackingWindow.gtag('event', name, params);
  };

  const eventParamsForLink = (link) => {
    const href = link.getAttribute('href') || '';
    const label = link.textContent?.trim().replace(/\s+/g, ' ').slice(0, 80) || href;

    if (href.startsWith('mailto:')) {
      return { eventName: 'contact_email_click', params: { link_text: label } };
    }

    if (href.includes('linkedin.com') || href.includes('github.com') || href.includes('xing.com')) {
      return { eventName: 'social_click', params: { link_url: href, link_text: label } };
    }

    if (href.startsWith('/projects/')) {
      return { eventName: 'select_content', params: { content_type: 'project_case_study', item_id: href } };
    }

    if (href.startsWith('/blog/')) {
      return { eventName: 'select_content', params: { content_type: 'blog_article', item_id: href } };
    }

    if (href.startsWith('/cv/')) {
      return { eventName: 'view_cv', params: { link_text: label } };
    }

    if (href.startsWith('/contact/')) {
      return { eventName: 'contact_cta_click', params: { link_text: label } };
    }

    if (/^https?:\/\//.test(href)) {
      return { eventName: 'click', params: { link_url: href, outbound: true } };
    }

    return null;
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const link = target.closest('a');
    if (!(link instanceof HTMLAnchorElement)) return;

    const eventData = eventParamsForLink(link);
    if (!eventData) return;

    trackingWindow['trackSiteEvent']?.(eventData.eventName, eventData.params);
  });

  acceptButton?.addEventListener('click', () => saveConsent(true));
  rejectButton?.addEventListener('click', () => saveConsent(false));
  saveButton?.addEventListener('click', () => saveConsent(Boolean(statisticsCheckbox?.checked)));
  settingsButton?.addEventListener('click', () => {
    const state = readConsent();

    if (statisticsCheckbox) statisticsCheckbox.checked = Boolean(state?.analytics);
    if (consentBanner) consentBanner.hidden = false;
    settingsButton.hidden = true;
  });

  applyConsent(readConsent());
</script>
