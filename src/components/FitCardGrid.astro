---
interface Props {
  items: readonly { title: string; text: string }[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<div class:list={['grid gap-4 sm:grid-cols-2 lg:grid-cols-3', className]}>
  {
    items.map((card) => (
      <article class="feature-card">
        <h3 class="text-lg font-semibold text-[color:var(--ink)]">{card.title}</h3>
        <p class="mt-3 text-sm leading-7 text-[color:var(--muted-strong)]">{card.text}</p>
      </article>
    ))
  }
</div>
