---
import TechTag from '@components/TechTag.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="project-card surface-card interactive-card flex h-full flex-col">
  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-start justify-between gap-4">
      <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--accent-dark)]">{project.data.category}</span>
      <span class="rounded-md border border-[color:var(--line)] bg-[color:var(--surface)] px-2.5 py-1 text-xs font-medium text-[color:var(--sky-strong)]">
        {project.data.status}
      </span>
    </div>
    <h3 class="mt-5 text-xl font-semibold leading-snug text-[color:var(--ink)]">
      <a class="rounded-sm hover:text-[color:var(--accent-dark)]" href={`/projects/${project.data.slug}/`}>{project.data.title}</a>
    </h3>
    <p class="mt-3 flex-1 leading-7 text-[color:var(--muted)]">{project.data.description}</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {project.data.technologies.slice(0, 4).map((tech) => <TechTag label={tech} />)}
    </div>
    <a class="text-link mt-6 self-start" href={`/projects/${project.data.slug}/`}>
      Case Study lesen
      <span class="ml-2" aria-hidden="true">-&gt;</span>
    </a>
  </div>
</article>
