---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="card card-hover flex h-full flex-col">
  <div class="flex flex-wrap gap-2">
    {project.data.technologies.slice(0, 4).map((tech) => <span class="tag">{tech}</span>)}
  </div>
  <h3 class="mt-5 text-xl font-semibold text-zinc-950">
    <a href={`/projekte/${project.id}/`}>{project.data.title}</a>
  </h3>
  <p class="mt-3 flex-1 leading-7 text-zinc-600">{project.data.shortDescription}</p>
  <a class="mt-6 text-sm font-semibold text-teal-800 hover:text-zinc-950" href={`/projekte/${project.id}/`}>
    Projekt öffnen
  </a>
</article>
