---
import TechTag from '@components/TechTag.astro';
import type { Locale } from '@lib/i18n';
import { withLocalePath } from '@lib/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'> | CollectionEntry<'projectsEn'>;
}

const { project } = Astro.props;
const locale = project.data.locale as Locale;
const projectHref = withLocalePath(locale, `/projects/${project.data.slug}/`);
const copy = locale === 'de'
  ? {
      aria: `Case Study ${project.data.title} lesen`,
      impact: 'Ergebnis:',
      cta: 'Case Study lesen',
    }
  : {
      aria: `Read case study ${project.data.title}`,
      impact: 'Outcome:',
      cta: 'Read case study',
    };
---

<article class="h-full">
  <a
    class="project-card surface-card interactive-card flex h-full flex-col no-underline"
    href={projectHref}
    aria-label={copy.aria}
  >
    <div class="flex flex-1 flex-col p-6 sm:p-7">
      <div class="flex items-start justify-between gap-4">
        <span class="meta-label text-[color:var(--accent-dark)]">{project.data.category}</span>
        <span class="meta-chip">
          {project.data.status}
        </span>
      </div>
      <h3 class="mt-6 text-2xl font-semibold leading-tight text-[color:var(--ink)]">
        {project.data.title}
      </h3>
      <div class="flex-1">
        <p class="mt-4 leading-7 text-[color:var(--muted)]">{project.data.description}</p>
        {project.data.impact && (
          <p class="mt-4 border-l-2 border-[color:var(--accent)] pl-4 text-sm leading-6 text-[color:var(--muted-strong)]">
            <span class="font-semibold text-[color:var(--ink)]">{copy.impact}</span> {project.data.impact}
          </p>
        )}
      </div>
      <div class="project-card-tags mt-6 flex flex-wrap gap-2">
        {project.data.technologies.slice(0, 4).map((tech) => <TechTag label={tech} />)}
      </div>
      <span class="card-cta mt-7 self-start">
        {copy.cta}
        <span class="card-cta-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20" focusable="false">
            <path d="M4 10h10" />
            <path d="m10 6 4 4-4 4" />
          </svg>
        </span>
      </span>
    </div>
  </a>
</article>
