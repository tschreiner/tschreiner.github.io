---
import Container from '@components/Container.astro';
import { Picture } from 'astro:assets';
import heroImage from '../assets/images/tedd-schreiner-hero.jpg';
---

<section class="hero-section relative overflow-hidden">
  <Picture
    src={heroImage}
    alt="Portrait von Tedd Schreiner auf einer Treppe"
    formats={['avif', 'webp']}
    widths={[720, 960, 1280, 1600, 1920]}
    sizes="100vw"
    class="hero-media"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>

  <Container class="relative z-10 grid min-h-[calc(100svh-4rem)] content-center py-10 sm:py-16 lg:min-h-[640px] lg:py-14">
    <div class="max-w-4xl">
      <p class="eyebrow max-w-xs text-[0.7rem] leading-5 tracking-[0.16em] text-[color:var(--gold)] sm:max-w-none sm:text-xs sm:tracking-[0.18em]">
        DevOps · AWS Cloud · Automation · AI Software Engineering
      </p>

      <h1 class="mt-4 max-w-4xl text-[2rem] font-semibold leading-[1.16] text-[color:var(--warm-text)] sm:text-5xl lg:text-5xl">
        DevOps Engineer für AWS Cloud, Automatisierung und AI Software Engineering.
      </h1>

      <p class="mt-5 max-w-2xl text-base leading-7 text-[color:var(--warm-text)] sm:text-xl sm:leading-8">
        Ich entwickle und betreibe Cloud-Infrastruktur, CI/CD-Workflows und Automatisierungen, die Software-Deployments,
        ITSM-Prozesse und Netzwerkbetrieb verlässlicher machen.
      </p>

      <p class="mt-4 max-w-2xl text-sm leading-7 text-[color:var(--warm-muted)] sm:text-lg sm:leading-8">
        Erfahrung mit AWS, GitHub/GitLab Workflows, Kubernetes, Linux, Netzwerkautomatisierung und AI-gestützten
        Engineering-Prozessen.
      </p>

      <div class="mt-6 flex flex-col gap-2.5 sm:mt-7 sm:flex-row sm:items-center sm:gap-3">
        <a class="button-primary" href="/cv/">CV ansehen</a>
        <a class="button-secondary" href="/contact/">Kontakt aufnehmen</a>
        <a class="text-link self-center text-[color:var(--warm-text)] hover:bg-white/10 hover:text-white sm:self-auto" href="/projects/">
          Case Studies
        </a>
      </div>

      <dl class="mt-8 grid max-w-3xl gap-3 sm:grid-cols-3">
        {
          [
            ['Rollenfit', 'DevOps · Cloud · Platform'],
            ['Stack', 'AWS · Kubernetes · CI/CD'],
            ['Schwerpunkt', 'Automation & AI Software Engineering'],
          ].map(([label, value]) => (
            <div class="hero-metric">
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </Container>
</section>
