---
import Container from '@components/Container.astro';
---

<section class="hero-section relative overflow-hidden">
  <Container class="grid min-h-[calc(100vh-4rem)] items-center gap-10 py-12 lg:grid-cols-[1.14fr_0.86fr] lg:py-20">
    <div>
      <p class="eyebrow">DevOps · Automation · Builder</p>
      <h1 class="mt-5 max-w-4xl text-5xl font-semibold leading-tight text-[color:var(--ink)] sm:text-6xl">
        Tedd Schreiner
      </h1>
      <p class="mt-5 max-w-2xl text-xl leading-8 text-[color:var(--graphite)]">
        DevOps Engineer, Automatisierer und Builder von Web- und AI-Projekten.
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--muted)]">
        Ich arbeite an Infrastruktur, Netzwerkautomatisierung und technischen Systemen — und baue nebenbei Projekte,
        die Technik, Kreativität und Alltag miteinander verbinden.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button-primary" href="/projects/">Projekte ansehen</a>
        <a class="button-secondary" href="/cv/">Lebenslauf öffnen</a>
        <a class="button-secondary" href="/contact/">Kontakt aufnehmen</a>
      </div>
    </div>

    <div class="relative">
      <figure class="hero-photo-frame relative overflow-hidden rounded-lg">
        <img
          src="/images/tedd-schreiner-hero.jpg"
          alt="Portrait von Tedd Schreiner"
          class="aspect-[4/5] w-full object-cover"
          style="object-position: 52% 46%;"
          width="1600"
          height="1600"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <figcaption class="border-t border-white/10 bg-[color:var(--graphite)] p-5 text-sm text-[#f7ead9]">
          <p class="font-mono text-[#f0bf75]">system.focus = automation</p>
          <p class="mt-2 text-[#d8c8b4]">Infrastruktur, Datenqualität und saubere technische Abläufe.</p>
        </figcaption>
      </figure>
    </div>
  </Container>
</section>
