---
import Container from '@components/Container.astro';
import { Picture } from 'astro:assets';
import heroImage from '../assets/images/tedd-schreiner-hero.jpg';
---

<section class="hero-section relative overflow-hidden">
  <Picture
    src={heroImage}
    alt="Portrait von Tedd Schreiner auf einer Treppe"
    formats={['avif', 'webp']}
    widths={[720, 960, 1280, 1600, 1920]}
    sizes="100vw"
    class="hero-media"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>

  <Container class="relative z-10 grid min-h-[calc(100svh-4rem)] content-center py-14 sm:py-16 lg:min-h-[640px] lg:py-14">
    <div class="max-w-4xl">
      <p class="eyebrow text-[color:var(--gold)]">DevOps · Network Automation · Source of Truth</p>

      <h1 class="mt-4 max-w-4xl text-4xl font-semibold leading-tight text-[color:var(--warm-text)] sm:text-5xl lg:text-6xl">
        Tedd Schreiner baut robuste Automatisierung für Netzwerkbetrieb und Infrastruktur.
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-8 text-[color:var(--warm-text)] sm:text-xl">
        DevOps Engineering für Source-of-Truth-Daten, Netzwerkautomatisierung und technische Abläufe, die im Betrieb
        nachvollziehbar bleiben.
      </p>

      <p class="mt-4 max-w-2xl text-base leading-8 text-[color:var(--warm-muted)] sm:text-lg">
        Der Schwerpunkt liegt auf Linux-nahen Plattformen, Datenqualität, Dokumentation und Labs, die technische
        Entscheidungen prüfbar machen.
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a class="button-primary" href="/projects/">Case Studies ansehen</a>
        <a class="button-secondary" href="/contact/">Kontakt aufnehmen</a>
        <a class="text-link self-center text-[color:var(--warm-text)] hover:bg-white/10 hover:text-white sm:self-auto" href="/about/">
          Mehr über Tedd
        </a>
      </div>

      <dl class="mt-8 grid max-w-3xl gap-3 sm:grid-cols-3">
        {
          [
            ['Fokus', 'Network Automation'],
            ['Basis', 'Source-of-Truth-Daten'],
            ['Arbeitsweise', 'Pragmatisch dokumentiert'],
          ].map(([label, value]) => (
            <div class="hero-metric">
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </Container>
</section>
